<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/prompt_widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="10dp"
    android:background="@drawable/widget_prompt_bg">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Mem prompt jobs"
        android:textStyle="bold"
        android:textSize="13sp"
        android:textColor="#FFE8E8E8"
        android:paddingBottom="6dp" />

    <LinearLayout
        android:id="@+id/row_slot_0"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center_vertical"
        android:paddingTop="2dp"
        android:paddingBottom="2dp"
        android:orientation="horizontal">
        <TextView
            android:id="@+id/title_slot_0"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxLines="2"
            android:ellipsize="end"
            android:textSize="12sp"
            android:textColor="#FFB0B0B0"
            android:text="—" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/row_slot_1"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center_vertical"
        android:paddingTop="2dp"
        android:paddingBottom="2dp"
        android:orientation="horizontal">
        <TextView
            android:id="@+id/title_slot_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxLines="2"
            android:ellipsize="end"
            android:textSize="12sp"
            android:textColor="#FFB0B0B0"
            android:text="—" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/row_slot_2"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center_vertical"
        android:paddingTop="2dp"
        android:paddingBottom="2dp"
        android:orientation="horizontal">
        <TextView
            android:id="@+id/title_slot_2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxLines="2"
            android:ellipsize="end"
            android:textSize="12sp"
            android:textColor="#FFB0B0B0"
            android:text="—" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/row_slot_3"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center_vertical"
        android:paddingTop="2dp"
        android:paddingBottom="2dp"
        android:orientation="horizontal">
        <TextView
            android:id="@+id/title_slot_3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxLines="2"
            android:ellipsize="end"
            android:textSize="12sp"
            android:textColor="#FFB0B0B0"
            android:text="—" />
    </LinearLayout>
</LinearLayout>
